generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")       // pooled (port 6543) — used at runtime
  directUrl = env("DIRECT_URL")         // direct (port 5432) — used for migrations
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  phone     String?
  role      String   @default("Super Admin")
  createdAt DateTime @default(now())
}

model Category {
  id          String   @id @default(cuid())
  cid         String   @unique
  name        String
  slug        String   @unique
  desc        String?
  img         String?
  showNav     Boolean  @default(true)
  showHome    Boolean  @default(true)
  order       Int      @default(0)
  status      String   @default("Published")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  products    Product[]
}

model Product {
  id            String    @id @default(cuid())
  pid           String    @unique
  name          String
  shortDesc     String?
  fullDesc      String?
  img           String?
  price         Int
  disc          Int?
  discountLabel String?
  stock         Int       @default(0)
  lowAlert      Int       @default(10)
  status        String    @default("Published")
  visible       Boolean   @default(true)
  tags          String[]
  variants      Json      @default("[]")
  categoryId    String
  category      Category  @relation(fields: [categoryId], references: [id])
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  orderItems    OrderItem[]

  @@index([categoryId])
  @@index([status])
}

model Order {
  id             String      @id @default(cuid())
  orderId        String      @unique
  txId           String      @unique
  customerName   String
  customerPhone  String
  customerEmail  String?
  address        String
  city           String
  state          String
  pincode        String?
  subtotal       Int
  shipping       Int         @default(0)
  gst            Int         @default(0)
  total          Int
  payment        String
  status         String      @default("Completed")
  createdAt      DateTime    @default(now())
  items          OrderItem[]

  @@index([status])
  @@index([createdAt])
}

model OrderItem {
  id        String   @id @default(cuid())
  orderId   String
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id])
  name      String
  variant   String?
  qty       Int
  price     Int
  total     Int
}

model Settings {
  key   String @id
  value Json
}
